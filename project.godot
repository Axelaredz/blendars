; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Blend Ars"
run/main_scene="uid://cyqy6dvynho67"
config/features=PackedStringArray("4.6")

[autoload]

NetworkManager="*res://core/autoload/network_manager.gd"
GDAIMCPRuntime="*res://addons/gdai-mcp-plugin-godot/gdai_mcp_runtime.gd"
AppConfig="*uid://cjke6crjg14a0"
Nakama="*uid://bkgt8drgka7yy"
DebugMenu="*uid://cggqb75a8w8r"
UiTokens="*res://client/ui/ui_kit/tokens/ui_tokens.gd"
UiState="*res://client/ui/ui_kit/tokens/ui_state.gd"
UiNav="*res://client/ui/ui_kit/tokens/ui_navigation.gd"
SceneLoader="*uid://cbwmrnp0af35y"
ProjectMusicController="*uid://r5t485lr3p7t"
ProjectUISoundController="*uid://cc37235kj4384"

[dotnet]

project/assembly_name="Blend_ars"

[editor_plugins]

enabled=PackedStringArray("res://addons/InstanceDock/plugin.cfg", "res://addons/com.heroiclabs.nakama/plugin.cfg", "res://addons/debug_menu/plugin.cfg", "res://addons/gd-plug-ui/plugin.cfg", "res://addons/gdai-mcp-plugin-godot/plugin.cfg", "res://addons/maaacks_game_template/plugin.cfg", "res://addons/plugin_refresher/plugin.cfg", "res://addons/quill-ide/plugin.cfg")

[godots]

version_hint="4.6"

[gui]

theme/default_font_size=16

[internationalization]

locale/translations=PackedStringArray("res://addons/maaacks_game_template/base/translations/menus_translations.en.translation", "res://addons/maaacks_game_template/base/translations/menus_translations.fr.translation")

[maaacks_game_template]

disable_install_audio_busses=true
disable_update_check=false
disable_install_wizard=true

[network]

NetworkTime="*res://addons/netfox/NetworkTime.gd"
NetworkTimeSynchronizer="*res://addons/netfox/NetworkTimeSynchronizer.gd"
RollbackSynchronizer="*res://addons/netfox/RollbackSynchronizer.gd"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

