; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Blend Ars"
config/features=PackedStringArray("4.6")

[autoload]

NetworkManager="*res://core/autoload/network_manager.gd"
GDAIMCPRuntime="*res://addons/gdai-mcp-plugin-godot/gdai_mcp_runtime.gd"
AppConfig="*res://client/app_config.tscn"
Nakama="*uid://bkgt8drgka7yy"
DebugMenu="*uid://cggqb75a8w8r"
UiTokens="*res://client/ui/ui_kit/tokens/ui_tokens.gd"
UiState="*res://client/ui/ui_kit/tokens/ui_state.gd"
UiNav="*res://client/ui/ui_kit/tokens/ui_navigation.gd"

[dotnet]

project/assembly_name="Blend_ars"

[editor_plugins]

enabled=PackedStringArray("res://addons/com.heroiclabs.nakama/plugin.cfg", "res://addons/debug_menu/plugin.cfg", "res://addons/gd-plug-ui/plugin.cfg", "res://addons/gdai-mcp-plugin-godot/plugin.cfg")

[godots]

version_hint="4.6"

[gui]

theme/default_font_size=16

[network]

NetworkTime="*res://addons/netfox/NetworkTime.gd"
NetworkTimeSynchronizer="*res://addons/netfox/NetworkTimeSynchronizer.gd"
RollbackSynchronizer="*res://addons/netfox/RollbackSynchronizer.gd"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
